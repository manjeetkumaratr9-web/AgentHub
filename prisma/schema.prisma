generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Category {
  CUSTOMER_SUPPORT
  SALES
  APPOINTMENT_BOOKING
  HR
  EDUCATION
  REAL_ESTATE
  HEALTHCARE
  CUSTOM
}

enum AuthType {
  NONE
  API_KEY
  BEARER
  BASIC
}

enum PricingType {
  ONE_TIME
  SUBSCRIPTION
}

enum BillingPeriod {
  MONTHLY
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AccessType {
  ONE_TIME
  SUBSCRIPTION
}

enum AccessStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}

enum InvocationOutcome {
  SUCCESS
  CREATOR_ERROR
  CREATOR_TIMEOUT
  CREATOR_UNREACHABLE
  ACCESS_DENIED
  RATE_LIMITED
}

// ─── Auth.js required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Stripe buyer-side (populated on first checkout)
  stripeCustomerId String? @unique

  // Stripe seller-side (populated when creator onboards)
  stripeConnectAccountId String?  @unique
  stripeConnectOnboarded Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  listings        Listing[]
  accesses        Access[]
  apiKeys         ApiKey[]
  supportMessages SupportMessage[]
}

model Listing {
  id          String @id @default(cuid())
  creatorId   String
  creator     User   @relation(fields: [creatorId], references: [id])

  title       String
  slug        String        @unique
  description String        @db.Text
  category    Category

  // Creator's real endpoint — never exposed to buyers
  endpointUrl String
  authType    AuthType @default(NONE)

  // AES-256-GCM encrypted secret — null when authType = NONE
  authSecretCiphertext String?
  authSecretIv         String?
  authSecretAuthTag    String?

  // Free text describing expected request/response shape
  requestNotes String? @db.Text

  // Pricing
  pricingType   PricingType
  priceCents    Int
  billingPeriod BillingPeriod?

  // Cached on publish
  stripeProductId String?
  stripePriceId   String?

  status    ListingStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  accesses       Access[]
  invocationLogs InvocationLog[]

  @@index([creatorId])
  @@index([category])
  @@index([status])
}

// Unified entitlement — one model covers both one-time and subscription access
model Access {
  id        String  @id @default(cuid())
  listingId String
  buyerId   String
  listing   Listing @relation(fields: [listingId], references: [id])
  buyer     User    @relation(fields: [buyerId], references: [id])

  type   AccessType
  status AccessStatus @default(PENDING)

  stripeCheckoutSessionId String? @unique
  stripeSubscriptionId    String? @unique
  stripePaymentIntentId   String?

  // Subscription only — active until this date
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys        ApiKey[]
  invocationLogs InvocationLog[]
  supportThread  SupportThread?

  @@unique([listingId, buyerId])
  @@index([buyerId])
}

// Scoped API key per Access — shown once at creation, hash stored, never raw again
model ApiKey {
  id        String   @id @default(cuid())
  accessId  String
  access    Access   @relation(fields: [accessId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  keyHash   String   @unique
  keyPrefix String
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([accessId])
}

// Per-call log — does NOT store request/response bodies
model InvocationLog {
  id        String @id @default(cuid())
  listingId String
  accessId  String
  buyerId   String

  listing Listing @relation(fields: [listingId], references: [id])
  access  Access  @relation(fields: [accessId], references: [id])

  responseStatus   Int?
  requestSizeBytes Int?
  latencyMs        Int?
  outcome          InvocationOutcome

  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
  @@index([buyerId, createdAt])
  @@index([accessId, createdAt])
}

// One thread per Access — Creator<->Client human support/advisory
model SupportThread {
  id       String @id @default(cuid())
  accessId String @unique
  access   Access @relation(fields: [accessId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())
  messages  SupportMessage[]
}

model SupportMessage {
  id       String        @id @default(cuid())
  threadId String
  thread   SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId String
  sender   User          @relation(fields: [senderId], references: [id])

  body      String   @db.Text
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}
